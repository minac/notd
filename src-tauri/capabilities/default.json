{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-set-focus",
    "core:webview:default",
    "core:event:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-ask",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "https://**" },
        { "url": "http://**" },
        { "url": "mailto:**" }
      ]
    }
  ]
}
